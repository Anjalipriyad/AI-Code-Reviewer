# ╔══════════════════════════════════════════════════════════════╗
# ║         AI Code Reviewer — Environment Configuration        ║
# ╚══════════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=codereview
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=ai_code_reviewer
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Backend (FastAPI) ────────────────────────────────────────
BACKEND_PORT=8000
SECRET_KEY=generate-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-another-random-secret

# ── GitHub OAuth ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ── LLM / AI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-key   # Optional: for Claude support
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Observability (Optional) ────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=ai-code-reviewer
